# ============================================================
# HARMONIA HVAC AUTOMATION SYSTEM
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# ============================================================
# COMPANY INFORMATION
# ============================================================
COMPANY_NAME="Your HVAC Company Name"
COMPANY_PHONE="+15551234567"
COMPANY_TIMEZONE="America/New_York"
COMPANY_ADDRESS="123 Main St, City, State 12345"

# ============================================================
# SERVICETITAN CREDENTIALS
# Get these from: https://developer.servicetitan.io/
# ============================================================
ST_CLIENT_ID="your-client-id"
ST_CLIENT_SECRET="your-client-secret"
ST_TENANT_ID="your-tenant-id"
ST_APP_KEY="your-app-key"

# ServiceTitan Job Type IDs (find in ST Settings > Job Types)
DIAGNOSTIC_JOB_TYPE_ID="12345"
MAINTENANCE_JOB_TYPE_ID="12346"
INSTALL_JOB_TYPE_ID="12347"

# ============================================================
# VAPI CREDENTIALS
# Get these from: https://dashboard.vapi.ai/
# ============================================================
VAPI_API_KEY="your-vapi-api-key"
VAPI_PHONE_NUMBER_ID="your-vapi-phone-number-id"

# Vapi Assistant IDs (create these in Vapi dashboard)
VAPI_BOOKING_ASSISTANT_ID="asst_xxxxx"
VAPI_EMERGENCY_ASSISTANT_ID="asst_xxxxx"
VAPI_INBOUND_ASSISTANT_ID="asst_xxxxx"

# ============================================================
# TWILIO CREDENTIALS
# Get these from: https://console.twilio.com/
# ============================================================
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+15559876543"

# ============================================================
# AIRTABLE CREDENTIALS
# Get these from: https://airtable.com/create/tokens
# ============================================================
AIRTABLE_API_KEY="patXXXXXXXXXXXXXX.xxxxxxxxxxxxx"
AIRTABLE_BASE_ID="appXXXXXXXXXXXXXX"

# ============================================================
# OPENAI CREDENTIALS
# Get these from: https://platform.openai.com/api-keys
# ============================================================
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================
# SENDGRID CREDENTIALS
# Get these from: https://app.sendgrid.com/settings/api_keys
# ============================================================
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="service@yourhvaccompany.com"

# ============================================================
# GOOGLE SHEETS
# ============================================================
DEAD_LETTER_SHEET_ID="1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# LinkedIn Post Automation (workflow 07)
LINKEDIN_POSTS_SHEET_ID="your-linkedin-posts-spreadsheet-id"
MARKETING_POSTS_SHEET_ID="your-marketing-posts-spreadsheet-id"

# ============================================================
# LINKEDIN CREDENTIALS
# Set up at: https://www.linkedin.com/developers/apps
# ============================================================
LINKEDIN_ORG_ID="your-linkedin-organization-id"
APPROVAL_EMAIL="your-email@example.com"

# ============================================================
# TEAM PHONE NUMBERS
# ============================================================
MANAGER_PHONE="+15551112222"
TECH_LEAD_PHONE="+15553334444"
DISPATCH_PHONE="+15555556666"

# ============================================================
# BUSINESS CONFIGURATION
# ============================================================
# Pricing (in dollars)
DIAGNOSTIC_FEE="89"
EMERGENCY_FEE="149"
REACTIVATION_DISCOUNT="50"

# Business Hours (24h format)
BUSINESS_HOURS_START="8"
BUSINESS_HOURS_END="18"

# Lead Scoring Thresholds
LEAD_SCORE_HOT_THRESHOLD="80"
LEAD_SCORE_WARM_THRESHOLD="60"
LEAD_SCORE_COOL_THRESHOLD="40"

# ============================================================
# N8N CONFIGURATION
# ============================================================
N8N_WEBHOOK_URL="https://your-n8n-instance.com"
N8N_WEBHOOK_SECRET="your-secret-key-for-webhook-auth"

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_EMERGENCY_ROUTING="true"
ENABLE_LEAD_SCORING="true"
ENABLE_SMS_NOTIFICATIONS="true"
ENABLE_EMAIL_FOLLOWUP="true"
ENABLE_VAPI_OUTBOUND="true"

# ============================================================
# GOHIGHLEVEL CREDENTIALS
# Get these from: https://app.gohighlevel.com/ > Settings > API
# ============================================================
GHL_API_KEY="pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
GHL_LOCATION_ID="your-location-id"
GHL_API_VERSION="2021-07-28"
GHL_BASE_URL="https://services.leadconnectorhq.com"

# GHL Calendar IDs (find in GHL Settings > Calendars)
GHL_DEFAULT_CALENDAR_ID="calendar_default_id"
GHL_EMERGENCY_CALENDAR_ID="calendar_emergency_id"

# GHL Pipeline IDs (find in GHL Settings > Pipelines)
GHL_PIPELINE_ID="pipeline_main_id"
GHL_EMERGENCY_STAGE_ID="stage_emergency_id"
GHL_BOOKED_STAGE_ID="stage_booked_id"
GHL_WON_STAGE_ID="stage_won_id"
GHL_LOST_STAGE_ID="stage_lost_id"
GHL_REACTIVATION_PIPELINE_ID="pipeline_reactivation_id"
GHL_REACTIVATION_CONTACTED_STAGE_ID="stage_reactivation_contacted_id"

# ============================================================
# COLD CALLER DASHBOARD
# ============================================================
VITE_CALENDLY_URL=https://calendly.com/your-calendly-link
