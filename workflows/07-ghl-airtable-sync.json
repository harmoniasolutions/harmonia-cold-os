    {
      "parameters": {
        "jsCode": "// ============================================================\n// MAP OPPORTUNITY STATUS\n// Map GHL pipeline stages to Airtable Status values\n// ============================================================\n\nconst opportunities = $input.all();\nconst stageMap = { 'new': 'New', 'contacted': 'Contacted', 'qualified': 'Qualified', 'appointment scheduled': 'Booked', 'won': 'Closed-Won', 'lost': 'Closed-Lost', 'abandoned': 'Closed-Lost' };\n\nconst updates = [];\nfor (const opp of opportunities) {\n  const data = opp.json;\n  const stageName = (data.pipelineStageId_name || data.status || '').toLowerCase();\n  const airtableStatus = stageMap[stageName];\n  if (airtableStatus && data.contact?.id) {\n    updates.push({ json: { ghlContactId: data.contact.id, ghlOpportunityId: data.id, newStatus: airtableStatus, monetaryValue: data.monetaryValue || 0 } });\n  }\n}\n\nreturn updates.length > 0 ? updates : [{ json: { action: 'no_updates' } }];"
      },
