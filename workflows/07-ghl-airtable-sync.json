      "parameters": {
        "jsCode": "// ============================================================\n// PROCESS GHL TO AIRTABLE\n// Extract contacts array and map to processing format\n// ============================================================\n\nconst response = $input.first().json;\nconst contacts = response.contacts || [];\n\nif (contacts.length === 0) {\n  return [{ json: { _empty: true, contacts: [] } }];\n}\n\nconst mapped = contacts.map(c => ({\n  json: {\n    id: c.id,\n    firstName: c.firstName || '',\n    lastName: c.lastName || '',\n    email: c.email || '',\n    phone: c.phone || '',\n    address1: c.address1 || '',\n    city: c.city || '',\n    state: c.state || '',\n    postalCode: c.postalCode || '',\n    tags: c.tags || [],\n    customFields: c.customFields || [],\n    dateAdded: c.dateAdded || '',\n    dateUpdated: c.dateUpdated || '',\n    source: c.source || ''\n  }\n}));\n\nreturn mapped;"
      },
