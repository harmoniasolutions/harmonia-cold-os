    {
      "parameters": {
        "jsCode": "// ============================================================\n// RESOLVE CONFLICT AIRTABLE TO GHL\n// Compare timestamps - most recent wins\n// ============================================================\n\nconst lead = $('Prepare AT Lead').first().json;\nconst ghlContact = $input.first().json.contacts?.[0];\n\nif (!ghlContact) return { json: { action: 'skip' } };\n\nconst atUpdated = new Date(lead.fields?.['Last Contact'] || lead.createdTime || 0).getTime();\nconst ghlUpdated = new Date(ghlContact.dateUpdated || ghlContact.dateAdded || 0).getTime();\n\nif (atUpdated < ghlUpdated) return { json: { action: 'skip', reason: 'ghl_more_recent' } };\n\nreturn { json: { action: 'update', ghlContactId: ghlContact.id, updateBody: {\n  firstName: lead.fields['First Name'] || '', lastName: lead.fields['Last Name'] || '',\n  email: lead.fields['Email'] || '', phone: lead.fields['Phone'] || '',\n  address1: lead.fields['Address'] || '', city: lead.fields['City'] || '',\n  state: lead.fields['State'] || '', postalCode: lead.fields['Zip'] || '',\n  customFields: [\n    { key: 'harmonia_lead_score', value: String(lead.fields['Lead Score'] || '') },\n    { key: 'harmonia_lead_tier', value: lead.fields['Lead Tier'] || '' },\n    { key: 'harmonia_airtable_id', value: lead.id || '' }\n  ]\n} } };"
      },
