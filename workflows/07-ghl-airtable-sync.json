      "parameters": {
        "jsCode": "// ============================================================\n// PROCESS AIRTABLE TO GHL\n// Extract leads and filter out those with recent GHL sync\n// ============================================================\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const record = item.json;\n  if (!record.id || !record.fields) continue;\n\n  // Skip records that were just synced from GHL (within last 60 seconds)\n  const lastSynced = record.fields['GHL Last Synced'];\n  if (lastSynced) {\n    const syncAge = Date.now() - new Date(lastSynced).getTime();\n    if (syncAge < 60000) continue;\n  }\n\n  results.push({ json: record });\n}\n\nif (results.length === 0) {\n  return [{ json: { _empty: true } }];\n}\n\nreturn results;"
      },
