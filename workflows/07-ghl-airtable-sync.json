    {
      "parameters": {
        "jsCode": "// ============================================================\n// RESOLVE CONFLICT GHL TO AIRTABLE\n// Compare timestamps - most recent wins\n// If GHL wins, map fields to Airtable format\n// If Airtable wins, return action: skip\n// ============================================================\n\nconst ghlContact = $input.first().json;\nconst airtableRecord = $('Find Airtable Match').first().json;\n\nconst ghlUpdated = new Date(ghlContact.dateUpdated || ghlContact.dateAdded || 0).getTime();\nconst atUpdated = new Date(airtableRecord.fields?.['Last Contact'] || airtableRecord.createdTime || 0).getTime();\n\nif (ghlUpdated < atUpdated) return { json: { action: 'skip', reason: 'airtable_more_recent' } };\n\nconst updateFields = {};\nif (ghlContact.firstName) updateFields['First Name'] = ghlContact.firstName;\nif (ghlContact.lastName) updateFields['Last Name'] = ghlContact.lastName;\nif (ghlContact.email) updateFields['Email'] = ghlContact.email;\nif (ghlContact.address1) updateFields['Address'] = ghlContact.address1;\nif (ghlContact.city) updateFields['City'] = ghlContact.city;\nif (ghlContact.state) updateFields['State'] = ghlContact.state;\nif (ghlContact.postalCode) updateFields['Zip'] = ghlContact.postalCode;\n\nconst tags = ghlContact.tags || [];\nif (tags.includes('booked')) updateFields['Status'] = 'Booked';\nelse if (tags.includes('closed-won')) updateFields['Status'] = 'Closed-Won';\nelse if (tags.includes('closed-lost')) updateFields['Status'] = 'Closed-Lost';\n\nupdateFields['GHL Last Synced'] = new Date().toISOString();\n\nreturn { json: { action: 'update', airtableRecordId: airtableRecord.id, updateFields, ghlContactId: ghlContact.id } };"
      },
