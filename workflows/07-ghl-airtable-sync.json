      "parameters": {
        "jsCode": "// ============================================================\n// GET SYNC STATE\n// Read last sync timestamp from workflow static data\n// Default to 15 minutes ago if no previous sync\n// ============================================================\n\nconst staticData = $getWorkflowStaticData('global');\nconst lastSync = staticData.lastSyncTimestamp || new Date(Date.now() - 15 * 60 * 1000).toISOString();\nreturn { json: { lastSyncTimestamp: lastSync, lastSyncEpoch: new Date(lastSync).getTime(), currentRunTimestamp: new Date().toISOString() } };"
      },
