    {
      "parameters": {
        "jsCode": "// ============================================================\n// PREPARE EMERGENCY BOOKING\n// Sets emergency calendar, urgent priority, dispatch confirmation\n// ============================================================\n\nconst data = $input.first().json;\n\nreturn {\n  json: {\n    ...data,\n    ghlCalendarId: $env.GHL_EMERGENCY_CALENDAR_ID || $env.GHL_DEFAULT_CALENDAR_ID,\n    ghlPipelineId: $env.GHL_PIPELINE_ID || '',\n    ghlStageId: $env.GHL_EMERGENCY_STAGE_ID || '',\n    appointmentTitle: `EMERGENCY: ${data.issueDescription}`,\n    priority: 'urgent',\n    confirmationMessage: `EMERGENCY CONFIRMED: ${$env.COMPANY_NAME || 'Our team'} has a technician dispatching to ${data.address || 'your location'} NOW. Expected arrival: 30-60 minutes. If you smell gas, leave the building and call 911.`,\n    tags: ['emergency', 'booked', 'harmonia-booked', 'priority-dispatch']\n  }\n};"
      },
      "id": "prepare-emergency-booking",
      "name": "Prepare Emergency Booking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 250]
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// PREPARE ROUTINE BOOKING\n// Sets default calendar, normal priority, standard confirmation\n// ============================================================\n\nconst data = $input.first().json;\n\nconst startDate = new Date(data.appointmentStart);\nconst dateStr = startDate.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' });\nconst timeStr = startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });\n\nreturn {\n  json: {\n    ...data,\n    ghlCalendarId: $env.GHL_DEFAULT_CALENDAR_ID || '',\n    ghlPipelineId: $env.GHL_PIPELINE_ID || '',\n    ghlStageId: $env.GHL_BOOKED_STAGE_ID || '',\n    appointmentTitle: `${data.jobType.charAt(0).toUpperCase() + data.jobType.slice(1)}: ${data.customerName}`,\n    priority: 'normal',\n    confirmationMessage: `Hi ${data.firstName || 'there'}! Your ${data.jobType} appointment with ${$env.COMPANY_NAME || 'us'} is confirmed for ${dateStr} at ${timeStr}. Our tech will call 30 min before arrival. Reply HELP for support or STOP to cancel.`,\n    tags: ['booked', 'harmonia-booked']\n  }\n};"
      },
      "id": "prepare-routine-booking",
      "name": "Prepare Routine Booking",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [910, 550]
