    {
      "parameters": {
        "jsCode": "// ============================================================\n// DEAD LETTER QUEUE\n// Capture failed GHL calendar event creation for manual processing\n// ============================================================\n\nconst bookingData = $('Merge Contact Result').first().json;\nconst error = $input.first().json;\n\nreturn {\n  json: {\n    status: 'GHL_BOOKING_FAILED',\n    bookingData: {\n      customerName: bookingData.customerName,\n      phone: bookingData.phone,\n      email: bookingData.email,\n      address: bookingData.address,\n      appointmentStart: bookingData.appointmentStart,\n      appointmentEnd: bookingData.appointmentEnd,\n      jobType: bookingData.jobType,\n      issueDescription: bookingData.issueDescription,\n      isEmergency: bookingData.isEmergency,\n      ghlContactId: bookingData.ghlContactId,\n      priority: bookingData.priority,\n      leadScore: bookingData.leadScore,\n      leadTier: bookingData.leadTier\n    },\n    error: {\n      message: error.message || error.error || 'Unknown GHL API error',\n      statusCode: error.statusCode || error.code || null,\n      body: error.body || null\n    },\n    metadata: {\n      failedAt: new Date().toISOString(),\n      requiresManualBooking: true,\n      workflow: 'ghl-appointment-booking'\n    }\n  }\n};"
      },
      "id": "dead-letter-queue",
      "name": "Dead Letter Queue",
