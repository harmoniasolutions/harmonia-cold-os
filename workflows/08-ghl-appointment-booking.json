      "id": "appointment-webhook",
      "name": "Appointment Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 400]
    },
    {
      "parameters": {
        "jsCode": "// ============================================================\n// HARMONIA GHL APPOINTMENT DATA NORMALIZER\n// Standardizes appointment data from Vapi or internal triggers\n// ============================================================\n\nconst input = $input.first().json.body || $input.first().json;\n\nconst normalized = {\n  customerName: input.customer_name || input.customerName || input.name || '',\n  firstName: input.first_name || input.firstName || '',\n  lastName: input.last_name || input.lastName || '',\n  phone: '',\n  email: input.email || '',\n  address: input.address || input.service_address || '',\n  city: input.city || '',\n  state: input.state || '',\n  zip: input.zip || input.postal_code || '',\n  appointmentStart: input.selected_slot?.start || input.appointment_start || input.start || '',\n  appointmentEnd: input.selected_slot?.end || input.appointment_end || input.end || '',\n  jobType: input.job_type || input.jobType || 'diagnostic',\n  issueDescription: input.issue_description || input.issueDescription || input.notes || 'HVAC Service',\n  isEmergency: input.is_emergency || input.isEmergency || false,\n  bookedBy: input.booked_by || input.bookedBy || 'Vapi AI',\n  vapiCallId: input.vapi_call_id || input.vapiCallId || null,\n  serviceTitanBookingId: input.st_booking_id || input.serviceTitanBookingId || null,\n  airtableLeadId: input.airtable_lead_id || input.airtableLeadId || null,\n  ghlContactId: input.ghl_contact_id || input.ghlContactId || null,\n  leadScore: input.lead_score || input.leadScore || null,\n  leadTier: input.lead_tier || input.leadTier || null\n};\n\n// Clean phone number to E.164 format\nlet phone = (input.phone || input.customer_phone || '').replace(/\\D/g, '');\nif (phone.length === 10) phone = '+1' + phone;\nelse if (phone.length === 11 && phone.startsWith('1')) phone = '+' + phone;\nnormalized.phone = phone;\n\n// Build name from parts if full name not provided\nif (!normalized.firstName && normalized.customerName) {\n  const parts = normalized.customerName.trim().split(/\\s+/);\n  normalized.firstName = parts[0] || '';\n  normalized.lastName = parts.slice(1).join(' ') || '';\n}\n\n// Build full name if only parts provided\nif (!normalized.customerName) {\n  normalized.customerName = `${normalized.firstName} ${normalized.lastName}`.trim();\n}\n\nreturn { json: normalized };"
      },
      "id": "normalize-appointment",
      "name": "Normalize Appointment Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
