        "jsCode": "// ============================================================\n// USE EXISTING GHL CONTACT\n// Extract contact ID from search results\n// ============================================================\n\nconst searchResult = $input.first().json;\nconst bookingData = $('Merge Booking Prep').first().json;\nconst contact = searchResult.contacts[0];\n\nreturn {\n  json: {\n    ...bookingData,\n    ghlContactId: contact.id,\n    ghlContactExisted: true\n  }\n};"
