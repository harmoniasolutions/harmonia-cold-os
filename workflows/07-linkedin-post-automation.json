    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "// ============================================================\n// NORMALIZE DATA FROM BOTH SHEET FORMATS\n// Sheet 1: Post Description, Instructions, Image, Status, Output, Post Link\n// Sheet 2: name, idea, text, image, status\n// ============================================================\n\nconst items = $input.all();\nconst results = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const row = items[i].json;\n  let normalized;\n\n  // Detect Sheet 1 format (has 'Post Description' column)\n  if (row['Post Description'] !== undefined || row['Instructions'] !== undefined) {\n    normalized = {\n      source: 'linkedin_posts',\n      rowNumber: row['row_number'] || i + 2,\n      title: (row['Post Description'] || '').substring(0, 60) + '...',\n      description: row['Post Description'] || '',\n      fullText: '',\n      instructions: row['Instructions'] || '',\n      imageUrl: (row['Image'] || '').trim() || null,\n      sheetId: 'linkedin_posts'\n    };\n  }\n  // Detect Sheet 2 format (has 'name' and 'idea' columns)\n  else if (row['name'] !== undefined || row['idea'] !== undefined || row['text'] !== undefined) {\n    normalized = {\n      source: 'marketing_posts',\n      rowNumber: row['row_number'] || i + 2,\n      title: row['name'] || 'Untitled Post',\n      description: row['idea'] || '',\n      fullText: row['text'] || '',\n      instructions: '',\n      imageUrl: (row['image'] || '').trim() || null,\n      sheetId: 'marketing_posts'\n    };\n  } else {\n    continue;\n  }\n\n  // Convert Google Drive view URLs to direct download URLs\n  if (normalized.imageUrl && normalized.imageUrl.includes('drive.google.com')) {\n    const match = normalized.imageUrl.match(/\\/d\\/([a-zA-Z0-9_-]+)/);\n    if (match) {\n      normalized.imageUrl = 'https://drive.google.com/uc?export=download&id=' + match[1];\n    }\n  }\n\n  // Skip rows with no content at all\n  if (!normalized.description && !normalized.fullText) {\n    continue;\n  }\n\n  results.push({ json: normalized });\n}\n\nreturn results;"
      },
      "id": "normalize-data",
      "name": "Normalize Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 300]
    },
