        "jsCode": "// ============================================================\n// PREPARE UPDATE DATA FOR GOOGLE SHEETS\n// Handles both sheet formats with correct column names\n// ============================================================\n\nconst item = $input.first().json;\nconst postData = $('Restore Post Data').first().json;\n\n// Extract LinkedIn post URN from response\nconst linkedInResponse = item;\nconst postUrn = linkedInResponse.urn || linkedInResponse.id || '';\nconst shareUrn = linkedInResponse.activity || postUrn;\n\nreturn {\n  json: {\n    source: postData.source,\n    rowNumber: postData.rowNumber,\n    sheetId: postData.sheetId,\n    postUrn: postUrn,\n    shareUrn: shareUrn,\n    publishedAt: new Date().toISOString()\n  }\n};"
