    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": {
          "mode": "id",
          "value": "claude-sonnet-4-5-20250929"
        },
        "messages": {
          "values": [
            {
              "content": "={{ 'Generate a LinkedIn post based on the following content.\\n\\n' + ($json.description ? '## Post Description / Idea:\\n' + $json.description + '\\n\\n' : '') + ($json.fullText ? '## Reference Content (use as inspiration, rewrite in your own engaging style):\\n' + $json.fullText + '\\n\\n' : '') + ($json.instructions ? '## Formatting Instructions:\\n' + $json.instructions + '\\n\\n' : '## Default Instructions:\\nWrite an engaging, professional LinkedIn post. Include relevant emojis sparingly. End with a call-to-action question.\\n\\n') + 'Generate ONLY the post content. No titles, no labels, no markdown formatting - just the raw post text ready to publish.' }}",
              "role": "user"
            }
          ]
        },
        "simplify": true,
        "options": {
          "system": "You are an expert LinkedIn content creator writing posts for a professional organization page. Your posts are:\n\n1. HOOK-FIRST: Start with a bold, attention-grabbing first line that stops the scroll\n2. STRUCTURED: Use short paragraphs (1-3 sentences), line breaks for readability\n3. ENGAGING: Include relevant emojis where appropriate but don't overdo it\n4. VALUE-DRIVEN: Provide actionable insights, data, or unique perspectives\n5. CONVERSATIONAL: Write in a warm, approachable tone - not corporate jargon\n6. CTA-ENDING: End with a thought-provoking question or call-to-action\n\nRULES:\n- Output ONLY the post text, nothing else\n- No markdown formatting (no ##, no **, no ```)\n- No 'Here is your post:' or similar labels\n- Keep posts between 150-400 words for optimal engagement\n- Use line breaks generously for mobile readability\n- If hashtags are appropriate, add 3-5 relevant ones at the end\n- Follow any specific formatting instructions provided by the user",
          "maxTokens": 2048,
          "temperature": 0.7
        }
      },
      "id": "generate-content",
      "name": "Generate Content (Claude)",
      "type": "@n8n/n8n-nodes-langchain.anthropic",
      "typeVersion": 1,
      "position": [1620, 300]
    },
    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "// ============================================================\n// CLEAN AI OUTPUT & PREPARE FINAL POST CONTENT\n// ============================================================\n\nconst item = $input.first().json;\nconst postData = $('Loop Over Posts').first().json;\n\n// Get the generated text from Claude's response\nlet postContent = item.text || item.content || '';\n\n// Clean up common AI output artifacts\npostContent = postContent.trim();\npostContent = postContent.replace(/^[\"']|[\"']$/g, '');  // Strip surrounding quotes\npostContent = postContent.replace(/^(Here('s| is) (your |the |a )?(LinkedIn )?post:?\\s*\\n?)/i, '');  // Strip preamble\npostContent = postContent.replace(/^---\\n?/, '');  // Strip leading separator\npostContent = postContent.replace(/\\n?---$/, '');  // Strip trailing separator\npostContent = postContent.trim();\n\n// Validate content\nif (!postContent || postContent.length < 20) {\n  throw new Error('Generated content is too short or empty. Skipping this post.');\n}\n\nreturn {\n  json: {\n    postContent: postContent,\n    charCount: postContent.length,\n    wordCount: postContent.split(/\\s+/).filter(w => w.length > 0).length,\n    // Carry forward metadata for later nodes\n    source: postData.source,\n    rowNumber: postData.rowNumber,\n    title: postData.title,\n    imageUrl: postData.imageUrl,\n    sheetId: postData.sheetId\n  }\n};"
      },
      "id": "clean-content",
      "name": "Clean & Format Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1840, 300]
    },
    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "// ============================================================\n// PREPARE HTML EMAIL PREVIEW FOR APPROVAL\n// ============================================================\n\nconst item = $input.first().json;\n\n// Convert newlines to <br> for HTML display\nconst contentHtml = item.postContent\n  .replace(/&/g, '&amp;')\n  .replace(/</g, '&lt;')\n  .replace(/>/g, '&gt;')\n  .replace(/\\n/g, '<br>');\n\n// Build image preview section\nlet imageSection = '';\nif (item.imageUrl) {\n  imageSection = `\n    <div style=\"margin: 20px 0; text-align: center;\">\n      <p style=\"color: #666; font-size: 12px; margin-bottom: 8px;\">ATTACHED IMAGE:</p>\n      <img src=\"${item.imageUrl}\" alt=\"Post Image\" style=\"max-width: 100%; max-height: 400px; border-radius: 8px; border: 1px solid #e0e0e0;\" />\n    </div>`;\n}\n\n// Build the full HTML email\nconst emailHtml = `\n<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  <div style=\"background: linear-gradient(135deg, #0077B5 0%, #00A0DC 100%); color: white; padding: 20px; border-radius: 12px 12px 0 0;\">\n    <h2 style=\"margin: 0; font-size: 18px;\">LinkedIn Post Ready for Review</h2>\n    <p style=\"margin: 5px 0 0; opacity: 0.9; font-size: 13px;\">Source: ${item.source === 'linkedin_posts' ? 'LinkedIn Posts Sheet' : 'Marketing Posts Sheet'} | ${item.title}</p>\n  </div>\n  \n  <div style=\"background: #ffffff; border: 1px solid #e0e0e0; border-top: none; padding: 24px; border-radius: 0 0 12px 12px;\">\n    <div style=\"background: #f8f9fa; border-left: 4px solid #0077B5; padding: 16px 20px; border-radius: 0 8px 8px 0; margin-bottom: 20px;\">\n      <p style=\"margin: 0; font-size: 14px; line-height: 1.6; color: #333;\">${contentHtml}</p>\n    </div>\n    \n    ${imageSection}\n    \n    <div style=\"border-top: 1px solid #eee; padding-top: 16px; margin-top: 16px;\">\n      <table style=\"width: 100%; font-size: 12px; color: #888;\">\n        <tr>\n          <td>Characters: ${item.charCount}</td>\n          <td>Words: ${item.wordCount}</td>\n          <td>${item.imageUrl ? 'With Image' : 'Text Only'}</td>\n        </tr>\n      </table>\n    </div>\n  </div>\n</div>`;\n\nreturn {\n  json: {\n    ...item,\n    emailHtml: emailHtml,\n    emailSubject: '[LinkedIn Post Approval] ' + item.title\n  }\n};"
      },
