      "id": "lead-found-check",
      "name": "Lead Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1130, 400]
    },
    {
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an intent classifier for an HVAC company. Analyze the customer's SMS reply and classify it into EXACTLY one category.\n\nCategories:\n- INTERESTED: They want to book, said yes, want to learn more, asked about scheduling, expressed interest in the offer, or gave any positive response\n- NOT_INTERESTED: They declined, said no, not right now, maybe later, or gave a negative but polite response\n- STOP: They explicitly asked to stop texting, unsubscribe, remove them, or expressed anger about receiving messages\n- QUESTION: They asked a specific question that needs a human response (pricing, availability, technical question)\n\nRules:\n1. \"Yes\", \"Yeah\", \"Sure\", \"Ok\", \"Interested\", \"Tell me more\" = INTERESTED\n2. \"No thanks\", \"Not now\", \"Maybe later\" = NOT_INTERESTED  \n3. \"Stop\", \"Unsubscribe\", \"Remove me\", angry responses = STOP\n4. \"How much?\", \"When can you come?\", \"What's included?\" = QUESTION\n5. If unclear, default to QUESTION (human will handle)\n\nRespond with ONLY the category name in uppercase. Nothing else."
            },
            {
              "role": "user",
              "content": "=Customer's reply: \"{{ $('Parse Twilio Data').item.json.message }}\""
            }
          ]
        },
        "options": {
          "temperature": 0
        }
      },
      "id": "classify-intent",
      "name": "AI Classify Intent",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.6,
      "position": [1350, 400]
    },
    {
      "parameters": {
        "jsCode": "// Normalize and validate intent classification\nconst rawIntent = ($input.first().json.message?.content || $input.first().json.text || 'QUESTION').trim().toUpperCase();\nconst validIntents = ['INTERESTED', 'NOT_INTERESTED', 'STOP', 'QUESTION'];\n\nconst intent = validIntents.includes(rawIntent) ? rawIntent : 'QUESTION';\n\nconst leadData = $('Find Lead by Phone').first().json[0] || {};\nconst twilioData = $('Parse Twilio Data').first().json;\n\nreturn {\n  json: {\n    intent: intent,\n    confidence: validIntents.includes(rawIntent) ? 'high' : 'low',\n    leadId: leadData.id || null,\n    leadFields: leadData.fields || {},\n    originalMessage: twilioData.message,\n    phone: twilioData.from,\n    timestamp: twilioData.timestamp\n  }\n};"
      },
      "id": "normalize-intent",
      "name": "Normalize Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1570, 400]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "INTERESTED",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "INTERESTED"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "NOT_INTERESTED",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "NOT_INTERESTED"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "STOP",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "STOP"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.intent }}",
                    "rightValue": "QUESTION",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "renameOutput": true,
              "outputKey": "QUESTION"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
