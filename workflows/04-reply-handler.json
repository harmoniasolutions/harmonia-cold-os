      "id": "twilio-webhook",
      "name": "Twilio Inbound SMS",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "jsCode": "// Parse Twilio webhook payload (URL-encoded form data)\nconst body = $input.first().json.body || $input.first().json;\n\n// Normalize phone number to E.164\nlet fromNumber = body.From || '';\nfromNumber = fromNumber.replace(/\\D/g, '');\nif (fromNumber.length === 10) {\n  fromNumber = '+1' + fromNumber;\n} else if (fromNumber.length === 11 && fromNumber.startsWith('1')) {\n  fromNumber = '+' + fromNumber;\n} else if (!fromNumber.startsWith('+')) {\n  fromNumber = '+' + fromNumber;\n}\n\nreturn {\n  json: {\n    from: fromNumber,\n    fromRaw: body.From,\n    to: body.To,\n    message: body.Body || '',\n    messageLower: (body.Body || '').toLowerCase().trim(),\n    messageSid: body.MessageSid,\n    numMedia: parseInt(body.NumMedia) || 0,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
      "id": "parse-twilio",
      "name": "Parse Twilio Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-stop",
              "leftValue": "={{ ['stop', 'unsubscribe', 'cancel', 'quit', 'end'].includes($json.messageLower) }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "quick-stop-check",
      "name": "Quick STOP Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [690, 300]
