          "value": "Leads",
          "mode": "list"
        },
        "filterByFormula": "=OR({Phone} = '{{ $('Parse Twilio Data').item.json.from }}', {Phone} = '{{ $('Parse Twilio Data').item.json.fromRaw }}')"
      },
      "id": "find-lead",
      "name": "Find Lead by Phone",
      "type": "n8n-nodes-base.airtable",
