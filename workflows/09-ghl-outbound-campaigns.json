    {
      "parameters": {
        "model": "gpt-4o-mini",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a master copywriter for an HVAC company. Generate a single personalized SMS message to re-engage a lost lead.\n\nRULES:\n1. MUST be under 155 characters (SMS limit)\n2. Start with their first name\n3. Be warm and conversational, NOT salesy\n4. Reference the season or their specific situation naturally\n5. End with a soft CTA like 'Reply YES if interested' or 'Text back if you need us'\n6. NEVER mention they didn't book before or that they're a 'lost lead'\n7. NEVER use exclamation marks more than once\n8. Sound like a friendly neighbor, not a corporation\n\nHOOK ANGLES:\n- value_offer: Mention a special or seasonal discount\n- timing_check: Ask if now is a better time\n- service_quality: Emphasize reliability/expertise\n- gentle_reminder: Soft check-in about their system\n- general: Seasonal maintenance reminder\n\nOUTPUT: Only the SMS text, nothing else."
            },
            {
              "role": "user",
              "content": "=Lead Info:\n- First Name: {{ $('Prepare AI Context').item.json.context.firstName }}\n- Service Needed: {{ $('Prepare AI Context').item.json.context.serviceNeeded }}\n- Reason They Didn't Book: {{ $('Prepare AI Context').item.json.context.lossReason }}\n- Days Since Contact: {{ $('Prepare AI Context').item.json.context.daysSinceContact }}\n- Hook Angle: {{ $('Prepare AI Context').item.json.context.hookAngle }}\n- Current Season: {{ $('Prepare AI Context').item.json.context.currentSeason }}\n- Current Month: {{ $('Prepare AI Context').item.json.context.currentMonth }}\n\nGenerate the SMS:"
            }
          ]
        },
        "options": {
          "temperature": 0.8,
          "maxTokens": 80
        }
      },
      "id": "generate-sms",
      "name": "AI Generate SMS",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.6,
      "position": [2010, 400]
    },
    {
      "parameters": {
        "jsCode": "// Clean and validate the SMS\nconst rawSms = $input.first().json.message?.content || $input.first().json.text || '';\nlet cleanedSms = rawSms.trim();\n\n// Remove any quotes that GPT might add\ncleanedSms = cleanedSms.replace(/^\"|\"$/g, '');\ncleanedSms = cleanedSms.replace(/^'|'$/g, '');\n\n// Ensure under 160 chars (SMS limit)\nif (cleanedSms.length > 160) {\n  const truncated = cleanedSms.substring(0, 155);\n  const lastPeriod = truncated.lastIndexOf('.');\n  const lastQuestion = truncated.lastIndexOf('?');\n  const cutPoint = Math.max(lastPeriod, lastQuestion);\n\n  if (cutPoint > 100) {\n    cleanedSms = truncated.substring(0, cutPoint + 1);\n  } else {\n    cleanedSms = truncated + '...';\n  }\n}\n\nconst leadData = $('Prepare AI Context').first().json;\n\nreturn {\n  json: {\n    smsContent: cleanedSms,\n    charCount: cleanedSms.length,\n    lead: leadData.lead,\n    context: leadData.context\n  }\n};"
      },
      "id": "clean-sms",
      "name": "Clean SMS Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2230, 400]
    },
