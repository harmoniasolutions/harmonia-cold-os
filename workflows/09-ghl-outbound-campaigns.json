      "typeVersion": 3,
      "position": [910, 300]
    },
    {
      "parameters": {
        "jsCode": "// Prepare context for AI personalization\nconst lead = $input.first().json;\nconst currentMonth = new Date().toLocaleString('default', { month: 'long' });\nconst currentSeason = (() => {\n  const month = new Date().getMonth();\n  if (month >= 2 && month <= 4) return 'spring';\n  if (month >= 5 && month <= 7) return 'summer';\n  if (month >= 8 && month <= 10) return 'fall';\n  return 'winter';\n})();\n\n// Determine hook angle based on loss reason\nconst lossReason = (lead.fields['Loss Reason'] || '').toLowerCase();\nlet hookAngle = 'general';\n\nif (lossReason.includes('price') || lossReason.includes('cost')) {\n  hookAngle = 'value_offer';\n} else if (lossReason.includes('timing') || lossReason.includes('busy')) {\n  hookAngle = 'timing_check';\n} else if (lossReason.includes('competitor')) {\n  hookAngle = 'service_quality';\n} else if (lossReason.includes('not ready') || lossReason.includes('thinking')) {\n  hookAngle = 'gentle_reminder';\n}\n\nreturn {\n  json: {\n    lead: lead,\n    context: {\n      firstName: lead.fields['First Name'] || 'there',\n      lastName: lead.fields['Last Name'] || '',\n      phone: lead.fields['Phone'],\n      email: lead.fields['Email'] || null,\n      serviceNeeded: lead.fields['Service Needed'] || 'HVAC service',\n      lossReason: lead.fields['Loss Reason'] || 'no reason provided',\n      lastContact: lead.fields['Last Contact'],\n      hookAngle: hookAngle,\n      currentMonth: currentMonth,\n      currentSeason: currentSeason,\n      daysSinceContact: Math.floor((new Date() - new Date(lead.fields['Last Contact'])) / (1000 * 60 * 60 * 24)),\n      reactivationAttempt: (lead.fields['Reactivation Attempts'] || 0) + 1,\n      companyName: $env.COMPANY_NAME || 'our team'\n    }\n  }\n};"
      },
      "id": "prepare-context",
      "name": "Prepare AI Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1130, 300]
