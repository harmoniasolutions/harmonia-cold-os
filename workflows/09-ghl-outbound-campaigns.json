      "id": "check-ghl-dnc",
      "name": "Check GHL DNC",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1350, 300]
    },
    {
      "parameters": {
        "jsCode": "// Check DNC status from GHL contact lookup\nconst response = $input.first().json;\nconst contacts = response.contacts || [];\nconst contact = contacts[0];\n\nif (!contact) {\n  return { json: { isDNC: false, ghlContactId: null } };\n}\n\nconst tags = (contact.tags || []).map(t => t.toLowerCase());\nconst isDNC = tags.includes('dnc') || tags.includes('do-not-contact') || tags.includes('unsubscribed') || tags.includes('stop');\n\nreturn {\n  json: {\n    isDNC: isDNC,\n    ghlContactId: contact.id,\n    tags: contact.tags || []\n  }\n};"
      },
      "id": "parse-dnc-response",
      "name": "Parse DNC Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1570, 300]
